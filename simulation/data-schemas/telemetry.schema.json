{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Telemetry",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "temperature": { "type": "number" },
    "flow": { "type": "number" },
    "pressure": { "type": "number" }
  },
  "required": ["timestamp", "temperature"]
}
